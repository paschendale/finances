# =============================================================================
#  Finances — Docker overrides (optional)
# =============================================================================
#
#  You do not need this file. Defaults are baked into compose.yaml so this
#  works out of the box:
#
#    docker compose up --build
#
#  Copy this file to `.env` in the repo root only when you want to change
#  ports, secrets, or URLs. Docker Compose reads `.env` for ${VAR} substitution.
#
#  If you change APP_HTTP_PORT or POSTGREST_PORT, update APP_ORIGIN and
#  COMPOSE_VITE_APP_API_URL to match, then rebuild the app image:
#
#    docker compose build --no-cache app && docker compose up
#
# =============================================================================
#  Database
# =============================================================================

POSTGRES_PASSWORD=postgres

# =============================================================================
#  Auth (local use — replace if you care)
# =============================================================================

JWT_SECRET=local-docker-jwt-not-for-production
FINANCES_BOOTSTRAP_TOKEN=local-dev-login

# =============================================================================
#  Ports & browser-facing URLs
# =============================================================================

APP_HTTP_PORT=8080
POSTGREST_PORT=3000

# URL the browser uses to call PostgREST in the Docker-built UI only.
# (Repo VITE_APP_API_URL is for `npm run dev` and is not used here.)
COMPOSE_VITE_APP_API_URL=http://localhost:3000

# PostgREST CORS: must list the UI origin(s). Comma-separated.
APP_ORIGIN=http://localhost:8080,http://127.0.0.1:8080
